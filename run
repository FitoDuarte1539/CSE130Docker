#!/usr/bin/env bash
set -euo pipefail

FORCE=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    -f|--force)
      FORCE=true
      shift
      ;;
    *)
      echo "Usage: $0 [-f|--force]" >&2
      exit 1
      ;;
  esac
done

# If cse130, cse130-2, ... exist, return the first name that is not taken (starts at cse130-2 when base exists).
next_free_cse130_name() {
  local i=2
  local name
  while true; do
    name="cse130-$i"
    if ! docker container inspect "$name" >/dev/null 2>&1; then
      echo "$name"
      return
    fi
    i=$((i + 1))
  done
}

if docker container inspect cse130 >/dev/null 2>&1; then
  if [[ "$FORCE" != true ]]; then
    echo "Container 'cse130' already exists. Run this script with -f to create another container." >&2
    exit 1
  fi
  NAME="$(next_free_cse130_name)"
else
  NAME=cse130
fi

docker run -it \
  -v ~/.ssh:/root/.ssh:ro \
  -v ~/Desktop/Coding/testForCSE130Docker/persistentStorage:/workspace \
  --name "$NAME" \
  cse130-dev
